# ==============================================
# FRONTEND ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and update values

# API Base URL
# - Development (with Vite proxy): leave empty
# - Production (Nginx reverse proxy): leave empty
# - Production (separate domain): https://api.your-domain.com
# This is also used for Google OAuth2 start URL.
VITE_API_BASE_URL=

# PayPal Client ID (Sandbox)
# Lấy tại https://developer.paypal.com/dashboard/applications/sandbox
VITE_PAYPAL_CLIENT_ID=
